{
    "schemaVersion": 1,
    "id": "autobuilder",
    "version": "${version}",
    "name": "AutoBuilder",
    "description": "Automatically gathers materials and builds from Schematica/Litematica schematic files using Baritone",
    "authors": ["autobuilder"],
    "contact": {},
    "license": "MIT",
    "icon": "assets/autobuilder/icon.png",
    "environment": "client",
    "entrypoints": {
        "client": ["com.autobuilder.AutoBuilderMod"]
    },
    "depends": {
        "fabricloader": ">=0.18.0",
        "minecraft": "${minecraft_version}",
        "fabric-api": "*"
    }
}
